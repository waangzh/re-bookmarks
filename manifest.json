{
  "manifest_version": 3,
  "name": "ReMarks",
  "version": "1.6.0",
  "description": "ReMarks：使用 AI 智能分类整理浏览器书签",
  "permissions": ["bookmarks", "storage", "activeTab", "favicon", "sidePanel"],
  "host_permissions": ["<all_urls>"],
  "optional_permissions": ["history"],
  "action": {
    "default_title": "打开 ReMarks",
    "default_icon": {
      "16": "dist/icons/icon16.png",
      "32": "dist/icons/icon32.png",
      "48": "dist/icons/icon48.png",
      "128": "dist/icons/icon128.png"
    }
  },
  "options_page": "dist/options/index.html",
  "side_panel": {
    "default_path": "dist/sidebar/index.html"
  },
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "icons": {
    "16": "dist/icons/icon16.png",
    "32": "dist/icons/icon32.png",
    "48": "dist/icons/icon48.png",
    "128": "dist/icons/icon128.png"
  }
}
